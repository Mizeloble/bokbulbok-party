{
  "name": "bokbulbok-party",
  "version": "2.11.8",
  "private": false,
  "license": "MIT",
  "author": "Mizeloble (https://github.com/Mizeloble)",
  "description": "여럿이 모여 폰으로 즐기는 복불복 벌칙 정하기 파티 게임 — QR로 방을 열고 미니게임으로 누가 벌칙을 받을지 정해요.",
  "homepage": "https://github.com/Mizeloble/bokbulbok-party",
  "repository": {
    "type": "git",
    "url": "https://github.com/Mizeloble/bokbulbok-party.git"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "build": "next build && npm run build:server",
    "build:server": "rm -rf dist && esbuild server.ts --bundle --splitting --platform=node --target=node22 --format=esm --packages=external --outdir=dist --out-extension:.js=.mjs",
    "start": "NODE_ENV=production node dist/server.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "box2d-wasm": "7.0.0",
    "clsx": "2.1.1",
    "nanoid": "5.0.9",
    "next": "16.2.4",
    "qrcode": "1.5.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "socket.io": "4.8.1",
    "socket.io-client": "4.8.1",
    "zustand": "5.0.2"
  },
  "devDependencies": {
    "@types/node": "22.10.1",
    "@types/qrcode": "1.5.5",
    "@types/react": "19.2.1",
    "@types/react-dom": "19.2.1",
    "autoprefixer": "10.4.20",
    "esbuild": "0.28.1",
    "postcss": "8.4.49",
    "tailwindcss": "3.4.16",
    "tsx": "4.19.2",
    "typescript": "5.7.2",
    "vitest": "^2.1.9"
  }
}
