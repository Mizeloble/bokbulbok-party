# 크레딧 식별자 (빌드 시 주입, NEXT_PUBLIC_ 이라 클라 번들에 인라인됨).
# 미설정 시 src/lib/i18n.ts의 공개 fallback 사용 (복불복 / Mizeloble / GitHub 링크).
# 사내 배포는 GitHub Actions repo secret(CREDIT_ORG / CREDIT_AUTHOR / CREDIT_AUTHOR_URL)에서
# CI가 --build-arg로 주입함. 로컬에서 사내 표기를 보려면 .env.local에 아래를 채워 사용.
NEXT_PUBLIC_CREDIT_ORG=
NEXT_PUBLIC_CREDIT_AUTHOR=
# 비워두면 링크 없이 텍스트로 렌더 (사내 ID는 공개 URL이 없음).
NEXT_PUBLIC_CREDIT_AUTHOR_URL=
