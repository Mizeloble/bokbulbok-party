# 크레딧 식별자 (빌드 시 주입, NEXT_PUBLIC_ 이라 클라 번들에 인라인됨).
# 미설정 시 src/lib/i18n.ts의 공개 fallback 사용 (복불복 / Mizeloble / GitHub 링크).
# 사내 배포는 GitHub Actions repo secret(CREDIT_ORG / CREDIT_AUTHOR / CREDIT_AUTHOR_URL)에서
# CI가 --build-arg로 주입함. 로컬에서 사내 표기를 보려면 .env.local에 아래를 채워 사용.
NEXT_PUBLIC_CREDIT_ORG=
NEXT_PUBLIC_CREDIT_AUTHOR=
# 비워두면 링크 없이 텍스트로 렌더 (사내 ID는 공개 URL이 없음).
NEXT_PUBLIC_CREDIT_AUTHOR_URL=

# 광고 (공개 서비스 수익화). 기본 'none' → 광고 미로딩(개발·오픈소스 기본).
# 'adfit'(카카오 애드핏, 한국 타겟 권장) 또는 'adsense'(구글 애드센스)로 켬.
# NEXT_PUBLIC_ 이라 클라 번들에 인라인됨 — 자리별 단위 ID를 직접 채워야 송출됨.
NEXT_PUBLIC_AD_NETWORK=none
# 카카오 애드핏: 자리마다 발급받은 광고 단위(data-ad-unit) ID.
NEXT_PUBLIC_ADFIT_UNIT_LOBBY=
NEXT_PUBLIC_ADFIT_UNIT_RESULT=
NEXT_PUBLIC_ADFIT_UNIT_LANDING=
# 구글 애드센스: 퍼블리셔 클라이언트(ca-pub-…) + 자리별 슬롯 ID.
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_SLOT_LOBBY=
NEXT_PUBLIC_ADSENSE_SLOT_RESULT=
NEXT_PUBLIC_ADSENSE_SLOT_LANDING=

# 공개 사이트 URL — 공유 미리보기(OG)·메타 절대경로 기준. 프로덕션은 본인 도메인.
# 미설정 시 http://localhost:3000 (개발).
NEXT_PUBLIC_SITE_URL=

# 분석 — 광고와 별개. 기본 'none' → 미로딩. 'plausible'(쿠키리스 권장) 또는 'ga'(GA4).
NEXT_PUBLIC_ANALYTICS_PROVIDER=none
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_GA_ID=
